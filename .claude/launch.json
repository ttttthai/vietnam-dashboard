{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static-server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "vnstock-api",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["server:app", "--host", "0.0.0.0", "--port", "8001", "--reload"],
      "port": 8001
    }
  ]
}
